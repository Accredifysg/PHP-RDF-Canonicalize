parameters:
    level: max
    paths:
        - src
        - tests
    excludePaths:
        # Submodule (w3c/rdf-canon) — third-party fixtures, not our code.
        - tests/w3c/*
        # Pest harness test files use $this binding to PHPUnit's TestCase at
        # runtime, which PHPStan can't statically follow. The supporting
        # classes (Harness, TestCase) are still analysed.
        - tests/W3c/Algorithms/*
